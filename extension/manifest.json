{
  "manifest_version": 3,
  "name": "Faust Commerce Bridge",
  "version": "1.1.0",
  "description": "Scan source products, analyze profitability, import to Faust, and assist marketplace publishing.",
  "permissions": ["activeTab", "scripting", "storage", "sidePanel", "tabs"],
  "host_permissions": [
    "https://*.superbuy.com/*",
    "https://*.1688.com/*",
    "https://*.depop.com/*",
    "https://*.ebay.com/*",
    "https://*.etsy.com/*",
    "https://*.mercari.com/*",
    "https://*.poshmark.com/*",
    "http://localhost:3000/*",
    "https://faust-os-staging.vercel.app/*",
    "https://*.faust.local/*"
  ],
  "background": { "service_worker": "background.js", "type": "module" },
  "icons": {
    "16": "assets/faust-logo-16.png",
    "20": "assets/faust-logo-20.png",
    "24": "assets/faust-logo-24.png",
    "32": "assets/faust-logo-32.png",
    "48": "assets/faust-logo-48.png",
    "64": "assets/faust-logo-64.png",
    "96": "assets/faust-logo-96.png",
    "128": "assets/faust-logo-128.png",
    "256": "assets/faust-logo-256.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Faust Commerce Bridge",
    "default_icon": {
      "16": "assets/faust-logo-16.png",
      "20": "assets/faust-logo-20.png",
      "24": "assets/faust-logo-24.png",
      "32": "assets/faust-logo-32.png",
      "48": "assets/faust-logo-48.png",
      "64": "assets/faust-logo-64.png",
      "96": "assets/faust-logo-96.png",
      "128": "assets/faust-logo-128.png",
      "256": "assets/faust-logo-256.png"
    }
  },
  "side_panel": { "default_path": "sidepanel.html" },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["https://*.superbuy.com/*", "https://*.1688.com/*"],
      "js": [
        "extractors/product.js",
        "utils/send.js",
        "content.js"
      ]
    },
    {
      "matches": ["https://*.depop.com/*", "https://*.ebay.com/*", "https://*.etsy.com/*", "https://*.mercari.com/*", "https://*.poshmark.com/*"],
      "js": ["adapters.js", "marketplace-content.js"]
    }
  ]
}
