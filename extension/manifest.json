{
  "manifest_version": 3,
  "name": "Faust Companion",
  "version": "0.2.0",
  "description": "Import Superbuy products into Faust OS.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "https://*.superbuy.com/*",
    "http://localhost:3000/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Import into Faust"
  },
  "content_scripts": [
    {
      "matches": ["https://*.superbuy.com/*"],
      "js": [
        "extractors/product.js",
        "utils/send.js",
        "content.js"
      ]
    }
  ]
}
