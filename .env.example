# Client-safe Supabase values. Never put service-role keys in this file.
FAUST_ENV=local
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Turn this on only after you configure Supabase Auth and run the migrations.
NEXT_PUBLIC_FAUST_AUTH_ENABLED=false
# Server only: used by background/admin jobs, never client-side code.
SUPABASE_SERVICE_ROLE_KEY=

# Storage buckets. Staging should use separate buckets from production.
SUPABASE_STORAGE_BUCKET_PRODUCT_IMAGES=product-images
SUPABASE_STORAGE_BUCKET_RECEIPTS=receipts
SUPABASE_STORAGE_BUCKET_LABELS=shipping-labels
SUPABASE_STORAGE_BUCKET_PACKING_PHOTOS=packing-photos
SUPABASE_STORAGE_BUCKET_EXTENSION_SCREENSHOTS=extension-screenshots
SUPABASE_STORAGE_BUCKET_EXTENSION_DOM_SNAPSHOTS=extension-dom-snapshots
SUPABASE_STORAGE_BUCKET_EXTENSION_LOGS=extension-logs
SUPABASE_STORAGE_BUCKET_PUBLISH_EVIDENCE=publish-evidence

# Worker deployment. Point this at the deployed app in staging/production.
AUTOMATION_WORKER_URL=http://localhost:3000/api/automations/actions
AUTOMATION_WORKER_ID=faust-worker-local
AUTOMATION_WORKER_CONCURRENCY=4
AUTOMATION_WORKER_POLL_MS=5000
AUTOMATION_WORKER_LEASE_MS=30000

# Extension bridge.
FAUST_ALLOWED_EXTENSION_ORIGINS=chrome-extension://*,http://localhost:3000,https://*.faust.local
FAUST_EXTENSION_TOKEN_TTL_SECONDS=3600

# Staging/live-connection checks.
STAGING_APP_URL=
AI_PROVIDER=deterministic
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
SHIPPING_PROVIDER=local_mock
EASYPOST_API_KEY=
SHIPPO_API_KEY=
